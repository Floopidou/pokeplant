<% content_for :body_class, "garden-body" %>
<% content_for :hide_navbar, "true" %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="garden-page pot-page" data-controller="care">

  <!-- Nav: back + coin badge -->
  <div class="pot-nav">
    <%= link_to plant_path(@plant), class: "pot-back-btn" do %><%= image_tag "arrow.svg", class: "back-arrow-img", alt: "back" %><% end %>
    <div class="garden-badge">
      <%= image_tag "leaf_coin.svg", class: "garden-badge-icon garden-coin-icon", alt: "coins" %>
      <%= current_user.leaf_coins %>
    </div>
  </div>

  <!-- Plant name + species -->
  <h1 class="garden-title pot-plant-name"><%= @plant.nickname %></h1>
  <p class="pot-plant-species"><%= @plant.common_name %></p>


  <!-- Avatar -->
  <div class="pot-avatar-zone">
    <% avatar = File.exist?(Rails.root.join("app/assets/images/avatars/#{@plant.avatar_img}")) ? "avatars/#{@plant.avatar_img}" : "avatars/undefined_pink_happy.png" %>
    <%= image_tag avatar, class: "pot-avatar plant-menu-avatar", alt: @plant.nickname %>
  </div>

  <!-- Pot Store tab card -->
  <div class="pot-bottom">

    <div class="pot-tab-nav">
      <button class="pot-tab pot-tab--active pot-store-tab">
      COLOR POT STORE
      </button>
    </div>

    <div class="pot-panel pot-store-panel">
      <div class="pot-store-grid">
        <% @pots.each do |pot| %>
          <div class="pot-store-card">
            <% pot_img = File.exist?(Rails.root.join("app/assets/images/pots/#{pot.pot_img}")) ? "pots/#{pot.pot_img}" : "pots/pink_pot.png" %>
            <div class="pot-store-img-wrap">
              <%= image_tag pot_img, class: "pot-store-img", alt: pot.color %>
              <% unless @owned_pairs[pot.id] %>
                <div class="pot-store-price-tag">
                  <%= image_tag "leaf_coin.svg", class: "pot-store-coin", alt: "leaf coin" %>
                  <span class="pot-store-price-text"><%= pot.leaf_coin_value %></span>
                </div>
              <% end %>
            </div>
            <p class="pot-store-name"><%= pot.color.upcase %></p>
            <% if (pair = @owned_pairs[pot.id]) %>
              <%= button_to plant_pot_plant_pot_pair_path(@plant, pot, pair), method: :patch, class: "pot-store-equip-btn" do %>
                EQUIP
              <% end %>
            <% else %>
              <%= button_to plant_pot_plant_pot_pairs_path(@plant, pot), method: :post, class: "pot-store-buy-btn" do %>
                BUY
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

  </div>

</div>
