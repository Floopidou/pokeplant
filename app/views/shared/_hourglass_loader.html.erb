<div class="hourglass-loader" data-hourglass-loader>
  <div class="hourglass-loader__spinner">
    <svg class="hourglass-loader__svg" width="176" height="220" viewBox="0 0 22 27" xmlns="http://www.w3.org/2000/svg">

      <!-- TOP FRAME -->
      <rect x="3" y="1" width="16" height="1" fill="#3A6A2A"/>
      <rect x="4" y="2" width="1" height="1" fill="#3A6A2A"/>
      <rect x="17" y="2" width="1" height="1" fill="#3A6A2A"/>

      <!-- TOP GLASS LEFT -->
      <rect x="5" y="2" width="1" height="2" fill="#6AAA50"/>
      <rect x="6" y="4" width="1" height="2" fill="#6AAA50"/>
      <rect x="7" y="6" width="1" height="1" fill="#6AAA50"/>
      <rect x="8" y="7" width="1" height="1" fill="#6AAA50"/>
      <rect x="9" y="8" width="1" height="1" fill="#6AAA50"/>
      <rect x="10" y="9" width="1" height="1" fill="#6AAA50"/>

      <!-- TOP GLASS RIGHT -->
      <rect x="16" y="2" width="1" height="2" fill="#6AAA50"/>
      <rect x="15" y="4" width="1" height="2" fill="#6AAA50"/>
      <rect x="14" y="6" width="1" height="1" fill="#6AAA50"/>
      <rect x="13" y="7" width="1" height="1" fill="#6AAA50"/>
      <rect x="12" y="8" width="1" height="1" fill="#6AAA50"/>
      <rect x="11" y="9" width="1" height="1" fill="#6AAA50"/>

      <!-- TOP GLASS CREAM -->
      <rect x="6" y="2" width="10" height="2" fill="#FFFDE5"/>
      <rect x="7" y="4" width="8" height="2" fill="#FFFDE5"/>
      <rect x="8" y="6" width="6" height="1" fill="#FFFDE5"/>
      <rect x="9" y="7" width="4" height="1" fill="#FFFDE5"/>
      <rect x="10" y="8" width="2" height="1" fill="#FFFDE5"/>

      <!-- SAND TOP -->
      <rect class="hourglass-loader__st1" x="9" y="6" width="4" height="1" fill="#e8899a"/>
      <rect class="hourglass-loader__st2" x="8" y="5" width="6" height="1" fill="#F2A0B0"/>
      <rect class="hourglass-loader__st3" x="7" y="4" width="8" height="1" fill="#F2A0B0"/>
      <rect class="hourglass-loader__st4" x="7" y="3" width="8" height="1" fill="#F9DFE4"/>

      <!-- SAND STREAM -->
      <g class="hourglass-loader__stream">
        <rect x="10" y="9" width="2" height="1" fill="#F2A0B0"/>
        <rect x="10" y="10" width="2" height="1" fill="#F2A0B0"/>
        <rect x="10" y="11" width="2" height="1" fill="#e8899a"/>
        <rect x="10" y="12" width="2" height="1" fill="#e8899a"/>
      </g>

      <!-- BOTTOM GLASS LEFT -->
      <rect x="10" y="11" width="1" height="1" fill="#6AAA50" opacity="0.4"/>
      <rect x="9" y="12" width="1" height="1" fill="#6AAA50"/>
      <rect x="8" y="13" width="1" height="1" fill="#6AAA50"/>
      <rect x="7" y="14" width="1" height="1" fill="#6AAA50"/>
      <rect x="6" y="15" width="1" height="2" fill="#6AAA50"/>
      <rect x="5" y="17" width="1" height="2" fill="#6AAA50"/>

      <!-- BOTTOM GLASS RIGHT -->
      <rect x="11" y="11" width="1" height="1" fill="#6AAA50" opacity="0.4"/>
      <rect x="12" y="12" width="1" height="1" fill="#6AAA50"/>
      <rect x="13" y="13" width="1" height="1" fill="#6AAA50"/>
      <rect x="14" y="14" width="1" height="1" fill="#6AAA50"/>
      <rect x="15" y="15" width="1" height="2" fill="#6AAA50"/>
      <rect x="16" y="17" width="1" height="2" fill="#6AAA50"/>

      <!-- BOTTOM GLASS CREAM -->
      <rect x="10" y="12" width="2" height="1" fill="#FFFDE5"/>
      <rect x="9" y="13" width="4" height="1" fill="#FFFDE5"/>
      <rect x="8" y="14" width="6" height="1" fill="#FFFDE5"/>
      <rect x="7" y="15" width="8" height="2" fill="#FFFDE5"/>
      <rect x="6" y="17" width="10" height="2" fill="#FFFDE5"/>

      <!-- SAND BOTTOM -->
      <rect class="hourglass-loader__sb1" x="6" y="18" width="10" height="1" fill="#e8899a"/>
      <rect class="hourglass-loader__sb2" x="7" y="17" width="8" height="1" fill="#F2A0B0"/>
      <rect class="hourglass-loader__sb3" x="7" y="16" width="8" height="1" fill="#F2A0B0"/>
      <rect class="hourglass-loader__sb4" x="8" y="15" width="6" height="1" fill="#F9DFE4"/>

      <!-- BOTTOM FRAME -->
      <rect x="4" y="19" width="1" height="1" fill="#3A6A2A"/>
      <rect x="17" y="19" width="1" height="1" fill="#3A6A2A"/>
      <rect x="3" y="20" width="16" height="1" fill="#3A6A2A"/>

    </svg>
  </div>

  <div class="hourglass-loader__text">
    <span class="hourglass-loader__letter">L</span>
    <span class="hourglass-loader__letter">O</span>
    <span class="hourglass-loader__letter">A</span>
    <span class="hourglass-loader__letter">D</span>
    <span class="hourglass-loader__letter">I</span>
    <span class="hourglass-loader__letter">N</span>
    <span class="hourglass-loader__letter">G</span>
    <span class="hourglass-loader__spacer"></span>
    <span class="hourglass-loader__dot hourglass-loader__dot--1">.</span>
    <span class="hourglass-loader__dot hourglass-loader__dot--2">.</span>
    <span class="hourglass-loader__dot hourglass-loader__dot--3">.</span>
  </div>
</div>
