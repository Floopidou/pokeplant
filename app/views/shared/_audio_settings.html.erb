<div id="audio-settings-panel" class="audio-settings-overlay" data-audio-target="panel">
  <div class="audio-settings-panel">

    <div class="reminders-panel-header">
      <h2 class="reminders-title">Settings</h2>
      <button class="reminders-close-btn" data-action="click->audio#closeSettings">✕</button>
    </div>

    <div class="audio-settings-body">

      <div class="audio-setting-row">
        <label class="audio-setting-label">🎵 Music</label>
        <input type="range" min="0" max="1" step="0.05" value="0.5"
               class="audio-slider"
               data-audio-target="musicSlider"
               data-action="input->audio#changeMusicVolume">
      </div>

      <div class="audio-setting-row">
        <label class="audio-setting-label">🔊 Effects</label>
        <input type="range" min="0" max="1" step="0.05" value="0.7"
               class="audio-slider"
               data-audio-target="sfxSlider"
               data-action="input->audio#changeSfxVolume">
      </div>

      <button class="audio-mute-btn" data-audio-target="muteBtn"
              data-action="click->audio#toggleMute">
        MUTE ALL
      </button>

      <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "audio-logout-btn" %>

    </div>
  </div>
</div>
