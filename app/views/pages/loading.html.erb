<% content_for :body_class, "garden-body" %>
<% content_for :hide_navbar, "true" %>

<div class="loader-page" data-controller="loader">

  <!-- Version badge -->
  <div class="loader-version">
    <%= image_tag "version.svg", alt: "version", class: "loader-version-img" %>
  </div>

  <!-- Logo centered -->
  <div class="loader-logo">
    <%= image_tag "pokeplant-logo.svg", class: "loader-logo-img", alt: "PokéPlant" %>
  </div>

  <!-- Progress bar -->
  <div class="loader-bottom">
    <p class="loader-status" data-loader-target="status">LOADING PLANTS...</p>
    <div class="loader-bar-track">
      <div class="loader-bar"></div>
    </div>
    <p class="loader-percent" data-loader-target="percent">0%</p>
  </div>

</div>
