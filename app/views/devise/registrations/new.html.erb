<div class="auth-page">
  <div class="auth-container">

    <div class="auth-logo">
       <div class="auth-logo">


      <%= image_tag "pokeplant-logo.svg", class: "auth-logo-svg", alt: "PokePlant logo" %>

    </div>
    </div>

    <div class="pixel-card">

      <div class="auth-tabs">
        <a href="<%= new_user_session_path %>" class="auth-tab">
          Connexion
        </a>
        <a href="<%= new_user_registration_path %>" class="auth-tab auth-tab--active">
          ▶ Inscription
        </a>
      </div>

      <div class="pixel-card-body">
        <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

          <%= f.error_notification message: f.object.errors.full_messages.join(", ") if f.object.errors.any? %>

          <%= f.input :username,
              label: "🌿 Pseudo",
              label_html: { class: "pixel-label" },
              wrapper_html: { class: "pixel-form-group" },
              input_html: {
                class: "pixel-input",
                placeholder: "mon_pseudo",
                autocomplete: "username"
              },
              required: true,
              autofocus: true,
              hint: "3-20 caractères, lettres, chiffres et _ uniquement" %>

          <%= f.input :email,
              label: "📧 Adresse Email",
              label_html: { class: "pixel-label" },
              wrapper_html: { class: "pixel-form-group" },
              input_html: {
                class: "pixel-input",
                placeholder: "plante@example.com",
                autocomplete: "email"
              },
              required: true %>

          <%= f.input :password,
              label: "🔒 Mot de passe",
              label_html: { class: "pixel-label" },
              wrapper_html: { class: "pixel-form-group" },
              input_html: {
                class: "pixel-input",
                placeholder: "••••••••",
                autocomplete: "new-password"
              },
              required: true,
              hint: @minimum_password_length ? "#{@minimum_password_length} caractères minimum" : nil %>

          <%= f.input :password_confirmation,
              label: "🔒 Confirmer le mot de passe",
              label_html: { class: "pixel-label" },
              wrapper_html: { class: "pixel-form-group" },
              input_html: {
                class: "pixel-input",
                placeholder: "••••••••",
                autocomplete: "new-password"
              },
              required: true %>

          <div class="pixel-form-actions">
            <%= f.button :submit, "✨ CRÉER MON COMPTE", class: "pixel-btn pixel-btn--pink w-100" %>
          </div>

        <% end %>

        <div class="pixel-divider">
          <span>~ ou ~</span>
        </div>

        <div class="auth-links">
          <%= link_to "Déjà un compte ? Se connecter", new_user_session_path, class: "pixel-link" %>
        </div>
      </div>
    </div>

    <div class="auth-decorations">
      <span>🌵</span>
      <span>🌿</span>
      <span>🍀</span>
      <span>🌸</span>
      <span>🪴</span>
    </div>

  </div>
</div>
