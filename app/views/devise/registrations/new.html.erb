<div class="auth-page">

  <div class="auth-container">
    <div class="auth-logo">
      <%= image_tag "pokeplant-logo.svg", class: "auth-logo-svg", alt: "PokePlant logo" %>
    </div>


    <div class="pixel-card">

      <div class="auth-tabs">
        <a href="<%= new_user_session_path %>" class="auth-tab">
          Log In
        </a>
        <a href="<%= new_user_registration_path %>" class="auth-tab auth-tab--active">
          Sign Up
        </a>
      </div>

      <div class="pixel-card-body">
        <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

          <%= f.error_notification message: f.object.errors.full_messages.join(", ") if f.object.errors.any? %>

          <%= f.input :username,
              label: false,
              label_html: { class: "pixel-label" },
              wrapper_html: { class: "pixel-form-group" },
              input_html: {
                class: "pixel-input",
                placeholder: "Your_nickname",
                autocomplete: "username"
              },
              required: true,
              autofocus: true,
              hint: "3-20 characters, letters, numbers and _ only" %>

          <%= f.input :birthdate,
              label: false,
              label_html: { class: "pixel-label" },
              wrapper_html: { class: "pixel-form-group" },
              input_html: {
                class: "pixel-input",
                placeholder: "YYYY/MM/DD",
                autocomplete: "date"
              },
              required: true %>

          <%= f.input :email,
              label: false,
              label_html: { class: "pixel-label" },
              wrapper_html: { class: "pixel-form-group" },
              input_html: {
                class: "pixel-input",
                placeholder: "plante@example.com",
                autocomplete: "email"
              },
              required: true %>


          <%= f.input :password,
              label: false,
              label_html: { class: "pixel-label" },
              wrapper_html: { class: "pixel-form-group" },
              input_html: {
                class: "pixel-input",
                placeholder: "password",
                autocomplete: "new-password"
              },
              required: true,
              hint: @minimum_password_length ? "#{@minimum_password_length} minimum characters" : nil %>

          <%= f.input :password_confirmation,
              label: false,
              label_html: { class: "pixel-label" },
              wrapper_html: { class: "pixel-form-group" },
              input_html: {
                class: "pixel-input",
                placeholder: "confirm_password",
                autocomplete: "new-password"
              },
              required: true %>

          <div class="pixel-form-actions">
            <%= f.button :submit, "✨ CREATE MY ACCOUNT", class: "pixel-btn pixel-btn--pink w-100" %>
          </div>

        <% end %>

        <div class="auth-links">
          <%= link_to "Already an account ? Please Log In", new_user_session_path, class: "pixel-link" %>
        </div>
      </div>
    </div>

  </div>
</div>
