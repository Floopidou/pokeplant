<div class="chat-page">
  <div class="chat-container">

    <!-- Header avec la plante -->
    <div class="chat-header">
      <div class="chat-plant-avatar">
        <%= image_tag "avatars/happy_monstera.svg", alt: "Monstera", class: "chat-avatar-img" %>
      </div>
      <div class="chat-plant-info">
        <h1 class="chat-plant-name">Monstera</h1>
        <span class="chat-plant-status">🌱 En ligne</span>
      </div>
    </div>

    <!-- Zone des messages -->
    <div class="chat-messages" id="chat-messages">

      <!-- Message de la plante -->
      <div class="chat-message chat-message--plant">
        <div class="chat-message-avatar">
          <%= image_tag "avatars/happy_monstera.svg", alt: "Monstera", class: "chat-message-avatar-img" %>
        </div>
        <div class="chat-bubble chat-bubble--plant">
          <p>Salut ! Je suis trop contente de te voir ! 🌿</p>
          <span class="chat-time">10:42</span>
        </div>
      </div>

      <!-- Message de l'utilisateur -->
      <div class="chat-message chat-message--user">
        <div class="chat-bubble chat-bubble--user">
          <p>Hey Monstera ! Comment tu vas aujourd'hui ?</p>
          <span class="chat-time">10:43</span>
        </div>
      </div>

      <!-- Message de la plante -->
      <div class="chat-message chat-message--plant">
        <div class="chat-message-avatar">
          <%= image_tag "avatars/happy_monstera.svg", alt: "Monstera", class: "chat-message-avatar-img" %>
        </div>
        <div class="chat-bubble chat-bubble--plant">
          <p>Je me sens super bien ! Mais j'aurais bien besoin d'un peu d'eau... 💧</p>
          <span class="chat-time">10:43</span>
        </div>
      </div>

      <!-- Message de l'utilisateur -->
      <div class="chat-message chat-message--user">
        <div class="chat-bubble chat-bubble--user">
          <p>Je m'en occupe tout de suite !</p>
          <span class="chat-time">10:44</span>
        </div>
      </div>

      <!-- Message de la plante -->
      <div class="chat-message chat-message--plant">
        <div class="chat-message-avatar">
          <%= image_tag "avatars/happy_monstera.svg", alt: "Monstera", class: "chat-message-avatar-img" %>
        </div>
        <div class="chat-bubble chat-bubble--plant">
          <p>Merci beaucoup ! Tu es le meilleur ami qu'une plante puisse avoir ! 💚✨</p>
          <span class="chat-time">10:44</span>
        </div>
      </div>

    </div>

    <!-- Zone de saisie -->
    <div class="chat-input-area">
      <%= form_with url: "#", method: :post, class: "chat-form", local: true do |f| %>
        <div class="chat-input-wrapper">
          <input type="text"
                 class="chat-input pixel-input"
                 placeholder="Parle à ta plante..."
                 autocomplete="off"
                 id="chat-input">
          <button type="submit" class="chat-send-btn pixel-btn pixel-btn--pink">
            ✨ Envoyer
          </button>
        </div>
      <% end %>
    </div>

  </div>
</div>
