<div class="chat-page">
  <div class="chat-container">

    <!-- Header -->
    <div class="chat-header">
      <div class="chat-plant-avatar">
        <%= image_tag "avatars/#{@plant.avatar_img}", alt: @plant.common_name, class: "chat-avatar-img" %>
      </div>
      <div class="chat-plant-info">
        <h1 class="chat-plant-name"><%= @plant.nickname || @plant.common_name %></h1>
        <span class="chat-plant-status">Chat History</span>
      </div>

      <% if @chats.any? %>
  <%= link_to plant_chat_path(@plant, @chats.first), class: "chat-back-link" do %>
    <%= image_tag "cross.svg", alt: "Close", class: "chat-close-icon" %>
  <% end %>
<% else %>
  <%= link_to plant_path(@plant), class: "chat-back-link" do %>
    <%= image_tag "cross.svg", alt: "Close", class: "chat-close-icon" %>
  <% end %>
<% end %>
    </div>

    <!-- Zone scrollable (comme chat-messages) -->
    <div class="chat-messages">

      <% if @chats.any? %>
        <div class="chats-list">
          <% @chats.each do |chat| %>
            <div class="chat-item">
              <%= link_to plant_chat_path(@plant, chat), class: "chat-item-link" do %>
                <div class="chat-item-info">
                  <span class="chat-item-date"><%= chat.created_at.strftime("%d/%m/%Y à %H:%M") %></span>
                  <span class="chat-item-preview">
                    <% if chat.messages.any? %>
                      <%= truncate(chat.messages.last.content, length: 50) %>
                    <% else %>
                      No message
                    <% end %>
                  </span>
                  <span class="chat-item-count"><%= chat.messages.count %> message<%= chat.messages.count > 1 ? 's' : '' %></span>
                </div>
              <% end %>

              <!-- Delete button -->
              <div data-controller="confirm-modal"
                   data-confirm-modal-title-value="Delete ?"
                   data-confirm-modal-message-value="This conversation will be lost forever 🥺"
                   data-confirm-modal-url-value="<%= plant_chat_path(@plant, chat) %>">
                <button type="button"
                        class="chat-item-delete"
                        data-action="click->confirm-modal#open">
                  <%= image_tag "garbage.svg", alt: "Delete", class: "btn-icon" %>
                </button>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="chats-empty blink">
          <p>No chat for the moment!</p>
          <p>Start a conversation with your plant 🌱</p>
        </div>
      <% end %>

    </div>

    <!-- Footer (comme chat-input-area) -->
    <div class="chat-input-area">
      <%= button_to plant_chats_path(@plant), method: :post, class: "pixel-btn pixel-btn--green chats-new-btn" do %>
        + NEW CHAT
      <% end %>
    </div>

  </div>
</div>
