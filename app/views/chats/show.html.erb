<div class="chat-page">
  <div class="chat-container"
       data-controller="chat-form"
       data-plant-avatar="<%= asset_path("avatars/#{@plant.avatar_img}") %>">

    <!-- Header avec la plante -->
    <div class="chat-header">
      <div class="chat-plant-avatar">
        <%= image_tag "avatars/#{@plant.avatar_img}", alt: @plant.common_name, class: "chat-avatar-img plant-chat-avatar" %>
        <%# image_tag "avatars/monstera_avatar.svg", alt: @plant.common_name, class: "chat-avatar-img" %>

      </div>
      <div class="chat-plant-info">
        <h1 class="chat-plant-name"><%= @plant.nickname || @plant.common_name %></h1>
        <span class="chat-plant-personality"><%= @plant.personality.capitalize %></span>
        <span class="chat-plant-status">
          <% case @plant.mood %>
          <% when :happy %>
            🌱 In shape !
          <% when :thirsty %>
            💧 A little thirsty...
          <% when :grumpy %>
            😤 Need more space
          <% when :lonely %>
            🥺 Miss You
          <% end %>
        </span>
      </div>

<!----------->
<%= link_to plant_chats_path(@plant, from_chat: @chat.id), class: "pixel-btn pixel-btn--pink-lite" do %>
 <%= image_tag "chat_history.svg", alt: "History", class: "btn-icon" %>
<% end %>
<!------->
     <%= link_to plant_path(@plant), class: "chat-back-link" do %>
        <%= image_tag "cross.svg", alt: "Close", class: "chat-close-icon" %>
      <% end %>
    </div>

    <!-- Zone des messages -->
    <div class="chat-messages" id="chat-messages" data-chat-form-target="messages">
  <% @messages.each do |message| %>
    <% if message.role == "user" %>
      <div class="chat-message chat-message--user">
        <div class="chat-bubble chat-bubble--user <%= 'chat-bubble--photo' if message.image.attached? %>">
          <% if message.image.attached? %>
            <%= image_tag message.image, class: "chat-photo", alt: "Photo" %>
          <% end %>
          <% if message.content.present? && message.content != "📷 Photo" %>
            <p><%= message.content %></p>
          <% end %>
          <span class="chat-time"><%= message.created_at.strftime("%H:%M") %></span>
        </div>
      </div>
    <% else %>
      <div class="chat-message chat-message--plant">
        <div class="chat-message-avatar">
          <%= image_tag "avatars/#{@plant.avatar_img}", alt: @plant.common_name, class: "chat-message-avatar-img" %>
        </div>
        <div class="chat-bubble chat-bubble--plant">
          <p><%= message.content %></p>
          <span class="chat-time"><%= message.created_at.strftime("%H:%M") %></span>
        </div>
      </div>
    <% end %>
  <% end %>

</div>

    <!-- Zone de saisie -->
<div class="chat-input-area" data-controller="photo-modal" data-photo-modal-url-value="<%= plant_chat_messages_path(@plant, @chat) %>">

  <%= form_with model: Message.new,
                url: plant_chat_messages_path(@plant, @chat),
                id: "chat-form",
                class: "chat-form",
                data: { action: "submit->chat-form#submit", no_loader: true } do |f| %>
    <div class="chat-input-wrapper">
      <div class="chat-input-container">
        <%= f.text_field :content,
                        class: "chat-input pixel-input",
                        placeholder: "Talk to your plant...",
                        autocomplete: "off",
                        id: "chat-input",
                        required: true,
                        data: { chat_form_target: "input" } %>
        <button type="submit"
                data-chat-form-target="button" class="send-btn">
          <%= image_tag "send.svg", alt:"send", class:"send-btn" %>
        </button>
      </div>
      <button type="button"
              class="chat-add-btn pixel-btn pixel-btn--green plus_btn"
              data-action="click->photo-modal#open">
        <%= image_tag "trombone.svg", alt: "clip", class: "btn-icon" %>
      </button>
    </div>
  <% end %>
</div>
<!--fin saisie-->
  </div>
</div>
