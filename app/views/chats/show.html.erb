<div class="chat-page">
  <div class="chat-container"
       data-controller="chat-form"
       data-chat-form-target="container"
       >

    <!-- Header avec la plante -->
    <div class="chat-header">
      <div class="chat-plant-avatar">
        <%# <%= image_tag "avatars/#{@plant.avatar_img}", alt: @plant.common_name, class: "chat-avatar-img" %>
        <%= image_tag "avatars/monstera_avatar.svg", alt: @plant.common_name, class: "chat-avatar-img" %>

      </div>
      <div class="chat-plant-info">
        <h1 class="chat-plant-name"><%= @plant.nickname || @plant.common_name %></h1>
        <span class="chat-plant-status">
          <% case @plant.mood %>
          <% when :happy %>
            🌱 In shape !
          <% when :thirsty %>
            💧 A little thirsty...
          <% when :grumpy %>
            😤 Need more space
          <% when :lonely %>
            🥺 Miss You
          <% end %>
        </span>
      </div>
     <%= link_to plant_menu_plant_path(@plant), class: "chat-back-link" do %>
        <%= image_tag "cross.svg", alt: "Close", class: "chat-close-icon" %>
      <% end %>
    </div>

    <!-- Zone des messages -->
    <div class="chat-messages" id="chat-messages" data-chat-form-target="messages">
      
      <% @messages.each do |message| %>
        <% if message.role == "user" %>
          <div class="chat-message chat-message--user">
            <div class="chat-bubble chat-bubble--user">
              <p><%= message.content %></p>
              <span class="chat-time"><%= message.created_at.strftime("%H:%M") %></span>
            </div>
          </div>
        <% else %>
          <div class="chat-message chat-message--plant">
            <div class="chat-message-avatar">
              <%# <%= image_tag "avatars/#{@plant.avatar_img}", alt: @plant.common_name, class: "chat-message-avatar-img" %>
              <%= image_tag "avatars/monstera_avatar.svg", alt: @plant.common_name, class: "chat-message-avatar-img" %>
            </div>
            <div class="chat-bubble chat-bubble--plant">
              <p><%= message.content %></p>
              <span class="chat-time"><%= message.created_at.strftime("%H:%M") %></span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- Zone de saisie -->
    <div class="chat-input-area">
      <%= form_with model: Message.new,
                    url: plant_chat_messages_path(@plant, @chat),
                    class: "chat-form",
                    data: { action: "submit->chat-form#submit" } do |f| %>
        <div class="chat-input-wrapper">
          <%= f.text_field :content,
                           class: "chat-input pixel-input",
                           placeholder: "Talk to your plant...",
                           autocomplete: "off",
                           id: "chat-input",
                           required: true,
                           data: { chat_form_target: "input" } %>
          <button type="submit"
                  class="chat-send-btn pixel-btn pixel-btn--pink"
                  data-chat-form-target="button">
            SEND
          </button>
        </div>
      <% end %>
    </div>

  </div>
</div>
