<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pokeplant" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
    <meta name="color-scheme" content="light">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Pokeplant">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload", media: "all" %>
    <%= javascript_importmap_tags %>
  </head>

  <% bgm_tracks = Dir.glob(Rails.root.join("public/sounds/bgm/*.mp3")).map { |f| "/sounds/bgm/#{File.basename(f)}" }.to_json %>
  <body class="<%= content_for(:body_class) %>"
        <% if user_signed_in? && @reminders %>
          data-controller="reminders"
          data-reminders-count-value="<%= @reminder_count %>"
        <% end %>>
    <div id="pp-audio"
         data-turbo-permanent
         data-controller="audio"
         data-audio-bgm-tracks-value="<%= bgm_tracks %>"
         data-audio-water-url-value="/sounds/sfx/water.mp3"
         data-audio-click-url-value="/sounds/sfx/click.mp3"
        data-audio-reminders-url-value="/sounds/sfx/reminders.mp3">
      <audio id="pp-music" data-audio-target="music"></audio>
      <%= render "shared/audio_settings" %>
    </div>

    <div id="page-loader" class="page-loader" data-controller="page-loader" data-turbo-permanent>
      <%= render "shared/hourglass_loader" %>
    </div>

    <%= render "shared/flashes" %>

    <% if user_signed_in? && @reminders && !content_for?(:hide_reminders) %>
      <% if @reminder_count > 0 %>
        <button class="garden-badge--bell" data-reminders-target="bell" data-action="click->reminders#open">
          <svg width="38" height="33" viewBox="0 0 60 52" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges">
            <rect x="4" y="4" width="56" height="48" fill="#864B39"/>
            <rect x="0" y="0" width="56" height="48" fill="#864B39"/>
            <rect x="4" y="4" width="48" height="24" fill="#FFFDE5"/>
            <rect x="4" y="28" width="48" height="16" fill="#F9DFE4"/>
            <rect x="8"  y="8"  width="4" height="4" fill="#F2A0B0"/>
            <rect x="12" y="12" width="4" height="4" fill="#F2A0B0"/>
            <rect x="16" y="16" width="4" height="4" fill="#F2A0B0"/>
            <rect x="20" y="20" width="4" height="4" fill="#F2A0B0"/>
            <rect x="24" y="24" width="4" height="4" fill="#F2A0B0"/>
            <rect x="44" y="8"  width="4" height="4" fill="#F2A0B0"/>
            <rect x="40" y="12" width="4" height="4" fill="#F2A0B0"/>
            <rect x="36" y="16" width="4" height="4" fill="#F2A0B0"/>
            <rect x="32" y="20" width="4" height="4" fill="#F2A0B0"/>
            <rect x="28" y="24" width="4" height="4" fill="#F2A0B0"/>
          </svg>
          <span class="garden-badge-count"><%= @reminder_count %></span>
        </button>
      <% end %>
      <%= render "plants/reminders_popup", reminders: @reminders %>
    <% end %>

    <%= link_to "Skip to main content", "#main-content", class: "visually-hidden-focusable" %>
    <% unless content_for?(:hide_navbar) %>
      <header>
        <%# render "shared/navbar" %>
      </header>
    <% end %>

    <main id="main-content">
      <%= yield %>
    </main>

    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/service-worker", { scope: "/" })
      }
    </script>
  </body>
</html>
