<% content_for :body_class, "infos-body" %>
<% content_for :hide_navbar, "true" %>

<% light_need  = @plant.light_need.to_i.clamp(0, 10) %>
<% water_val   = @plant.watering_interval.to_i.clamp(0, 10) %>
<% light_fill_x = light_need > 0 ? (51.0 + light_need * 13.837).round(3) : nil %>
<% water_fill_x = water_val  > 0 ? (53.3386 + water_val * 13.8).round(3) : nil %>
<% light_ind_d  = (light_need * 14.1).round(2) %>
<% water_ind_d  = (water_val  * 14.1).round(2) %>

<div class="infos-page">

  <% infos_bg = case @plant.common_name.downcase
               when /golden pothos/ then "golden pothos.svg"
               when /monstera/      then "Info page plant.svg"
               else                      "bg undefined plant.svg"
               end %>
  <%= image_tag infos_bg, class: "infos-bg", alt: "" %>

  <div class="infos-top">
    <%= link_to plants_path, class: "infos-back" do %>
      <%= image_tag "arrow.svg", alt: "back" %>
    <% end %>
    <h1 class="infos-title"><%= @plant.common_name %></h1>
  </div>

  <div class="infos-card">
    <%= image_tag "card_care.svg", class: "infos-card-bg", alt: "" %>
    <div class="infos-card-content">

