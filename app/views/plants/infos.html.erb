<div class="slides-wrapper" data-controller="slide">
    <div class="slides-track" data-slide-target="track">

      <%# ── Slide 1 : description ── %>
      <div class="slide plant-description-card" style="background-image: url('<%= asset_path('card_slide.svg') %>');">
        <div class="card-content">
          <h2 class="scientific-name"><%= @plant.scientific_name %></h2>
          <h3 class="origin-region"><%= @plant.origin_region %></h3>
          <p class="description-text"><%= @plant.description %></p>
          <div class="plant-icon-footer">
            <%= image_tag "plant icon.svg", alt: "icon plant", class: "icon-mini-plant" %>
          </div>
        </div>
      </div>

      <%# ── Slide 2 : toxicity + type of soil ── %>
      <% toxicity_val = @plant.toxicity.to_i.clamp(0, 5) %>
      <div class="slide plant-description-card" style="background-image: url('<%= asset_path('card_slide.svg') %>');">
        <div class="card-content">
          <h2 class="scientific-name">Toxicity</h2>
          <div class="toxicity-row">
            <%= render "toxicity_pots", toxicity_val: toxicity_val %>
          </div>
          <h2 class="scientific-name">Type of soil</h2>
          <p class="description-text description-text--capitalize"><%= @plant.type_of_soil %></p>
          <div class="plant-icon-footer">
            <%= image_tag "maggot.svg", alt: "icon", class: "icon-mini-plant" %>
          </div>
        </div>
      </div>

      <%# ── Slide 3 : ideal pot size + optimal placement ── %>
      <div class="slide plant-description-card" style="background-image: url('<%= asset_path('card_slide.svg') %>');">
        <div class="card-content">
          <h2 class="scientific-name">Ideal pot size</h2>
          <div class="pot-size-row">
            <%= render "pot_size", ideal_pot_size: @plant.ideal_pot_size %>
          </div>
          <h2 class="scientific-name">Optimal placement</h2>
          <p class="description-text description-text--capitalize"><%= @plant.optimal_placement %></p>
          <div class="plant-icon-footer">
            <%= image_tag "sunlight icon.svg", alt: "icon", class: "icon-mini-plant" %>
          </div>
        </div>
      </div>

    </div>

    <div class="slides-dots">
      <span class="slides-dot active" data-slide-target="dot"></span>
      <span class="slides-dot" data-slide-target="dot"></span>
      <span class="slides-dot" data-slide-target="dot"></span>
    </div>
  </div>

</div>
