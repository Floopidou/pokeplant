<% content_for :body_class, "garden-body" %>
<% content_for :hide_navbar, "true" %>

<div class="garden-page name-page">

  <h1 class="garden-title">Name your plant</h1>

  <% avatar = File.exist?(Rails.root.join("app/assets/images/avatars/#{@plant.avatar_img}")) ? "avatars/#{@plant.avatar_img}" : "avatars/undefined_pink_happy.png" %>
  <%= image_tag avatar, class: "name-avatar", alt: @plant.common_name %>

  <form action="<%= apply_name_plant_path(@plant) %>" method="post" class="name-form">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <%= hidden_field_tag :_method, "patch" %>

    <input type="text" name="nickname" class="name-input"
           placeholder="e.g., Choubidou" autocomplete="off" maxlength="20">

    <button type="submit" class="garden-page-btn name-submit">
      <%= image_tag "button.svg", class: "pixel-btn-bg", alt: "" %>
      <span class="pixel-btn-label">Name my plant</span>
    </button>
  </form>

</div>
