<% content_for :body_class, "garden-body" %>
<% content_for :hide_navbar, "true" %>

<div class="garden-page plant-menu-page">

  <!-- Top badges -->
  <div class="garden-header">
    <div class="garden-badge">
      <%= image_tag "leaf_coin.png", class: "garden-badge-icon", alt: "plants" %>
      <%= current_user.plants.count %>/6
    </div>
    <div class="garden-badge">
      <%= image_tag "leaf_coin.png", class: "garden-badge-icon garden-coin-icon", alt: "coins" %>
      <%= current_user.leaf_coins %>
    </div>
  </div>

  <!-- Title -->
  <h1 class="garden-title plant-menu-title"><%= @plant.nickname %></h1>
  <p class="plant-menu-subtitle"><%= @plant.common_name %></p>

  <!-- Avatar with arrows -->
  <div class="plant-menu-avatar-row">
    <button class="plant-show-arrow" type="button">&#8249;</button>
    <% avatar = File.exist?(Rails.root.join("app/assets/images/avatars/#{@plant.avatar_img}")) ? "avatars/#{@plant.avatar_img}" : "avatars/happy_monstera.svg" %>
    <%= image_tag avatar, class: "plant-menu-avatar", alt: @plant.nickname %>
    <button class="plant-show-arrow" type="button">&#8250;</button>
  </div>

  <!-- Action buttons: 2 / 1 / 2 -->
  <div class="plant-action-grid">
    <div class="plant-action-row">
      <%= link_to "&nbsp;".html_safe, "javascript:history.back()", class: "plant-action-btn" %>
      <%= link_to plant_chats_path(@plant), class: "plant-action-btn", data: { turbo_method: :post } do %>
        <%= image_tag "chat_emote.svg", class: "plant-action-icon", alt: "chat" %>
      <% end %>
    </div>
    <div class="plant-action-row plant-action-row--center">
      <%= link_to plants_path, class: "plant-action-btn" do %>
        <%= image_tag "cross.svg", class: "plant-action-icon", alt: "" %>
      <% end %>
    </div>
    <div class="plant-action-row">
      <button class="plant-action-btn" type="button">
        <%= image_tag "paint.svg", class: "plant-action-icon", alt: "paint" %>
      </button>
      <button class="plant-action-btn" type="button">
        <%= image_tag "sword.svg", class: "plant-action-icon", alt: "sword" %>
      </button>
    </div>
  </div>

</div>
