<% content_for :body_class, "garden-body" %>
<% content_for :hide_navbar, "true" %>

<div class="garden-page plant-menu-page" data-controller="coming-soon">


  <!-- Title -->
  <h1 class="garden-title plant-menu-title"><%= @plant.nickname %></h1>
  <p class="plant-menu-subtitle"><%= @plant.common_name %></p>

  <!-- Avatar with arrows -->
  <div class="plant-menu-avatar-row">
    <%= link_to plant_path(@prev_plant), class: "plant-show-arrow" do %>&#8249;<% end %>
    <div class="plant-menu-avatar-wrap">
      <% avatar = File.exist?(Rails.root.join("app/assets/images/avatars/#{@plant.avatar_img}")) ? "avatars/#{@plant.avatar_img}" : "avatars/undefined_pink_happy.svg" %>
      <%= image_tag avatar, class: "plant-menu-avatar", alt: @plant.nickname %>
      <%= link_to infos_plant_path(@plant), class: "plant-info-btn" do %>
        <%= image_tag "info_page.svg", class: "plant-info-icon", alt: "info" %>
      <% end %>
    </div>
    <%= link_to plant_path(@next_plant), class: "plant-show-arrow" do %>&#8250;<% end %>
  </div>

  <!-- Action buttons: 2 / 1 / 2 -->
  <div class="plant-action-grid">
    <div class="plant-action-row">
      <%= link_to care_plant_path(@plant), class: "plant-action-btn", data: { delayed_nav: "" } do %>
        <%= image_tag "arrosoir (1).svg", class: "plant-action-icon", alt: "water" %>
      <% end %>
      <%= link_to plant_chats_path(@plant), class: "plant-action-btn", data: { turbo_method: :post } do %>
        <%= image_tag "chat_emote.svg", class: "plant-action-icon", alt: "chat" %>
      <% end %>
    </div>
    <div class="plant-action-row plant-action-row--center">
      <%= link_to plants_path, class: "plant-action-btn" do %>
        <%= image_tag "cross.svg", class: "plant-action-icon", alt: "" %>
      <% end %>
    </div>
    <div class="plant-action-row">
      <button class="plant-action-btn" type="button">
        <%= image_tag "paint.svg", class: "plant-action-icon", alt: "paint" %>
      </button>
      <button class="plant-action-btn" type="button"
              data-action="click->coming-soon#open">
        <%= image_tag "sword.svg", class: "plant-action-icon", alt: "sword" %>
      </button>
    </div>
  </div>

  <!-- Coming soon overlay -->
  <div class="coming-soon-overlay" data-coming-soon-target="overlay"
       data-action="click->coming-soon#close">
    <div class="coming-soon-panel">
      <p class="coming-soon-text">⚔️</p>
      <p class="coming-soon-title">Coming soon...</p>
      <p class="coming-soon-subtitle">Something exciting is growing 🌱</p>
    </div>
  </div>

</div>
