<% content_for :body_class, "garden-body" %>
<% content_for :hide_navbar, "true" %>

<div class="garden-page" data-controller="reminders" data-reminders-count-value="<%= @reminder_count %>">

  <!-- Top badges -->
  <div class="garden-header">
    <div class="garden-badge">
      <%= image_tag "pot-mini.svg", class: "garden-badge-icon", alt: "plants" %>
      <%= @total_plant_count %>
    </div>
    <div class="garden-badge">
      <%= image_tag "leaf_coin.svg", class: "garden-badge-icon garden-coin-icon", alt: "coins" %>
      <%= current_user.leaf_coins %>
    </div>
  </div>

  <button class="garden-badge--bell" data-reminders-target="bell" data-action="click->reminders#open">
    <svg width="38" height="33" viewBox="0 0 60 52" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges">
      <rect x="4" y="4" width="56" height="48" fill="#864B39"/>
      <rect x="0" y="0" width="56" height="48" fill="#864B39"/>
      <rect x="4" y="4" width="48" height="24" fill="#FFFDE5"/>
      <rect x="4" y="28" width="48" height="16" fill="#F9DFE4"/>
      <rect x="8"  y="8"  width="4" height="4" fill="#F2A0B0"/>
      <rect x="12" y="12" width="4" height="4" fill="#F2A0B0"/>
      <rect x="16" y="16" width="4" height="4" fill="#F2A0B0"/>
      <rect x="20" y="20" width="4" height="4" fill="#F2A0B0"/>
      <rect x="24" y="24" width="4" height="4" fill="#F2A0B0"/>
      <rect x="44" y="8"  width="4" height="4" fill="#F2A0B0"/>
      <rect x="40" y="12" width="4" height="4" fill="#F2A0B0"/>
      <rect x="36" y="16" width="4" height="4" fill="#F2A0B0"/>
      <rect x="32" y="20" width="4" height="4" fill="#F2A0B0"/>
      <rect x="28" y="24" width="4" height="4" fill="#F2A0B0"/>
    </svg>
    <% if @reminder_count > 0 %>
      <span class="garden-badge-count"><%= @reminder_count %></span>
    <% end %>
  </button>

  <%= render "plants/reminders_popup", reminders: @reminders %>

  <!-- Title -->
  <h1 class="garden-title">The Garden</h1>

  <!-- Swipeable plant grid -->
  <div class="garden-swipe" data-controller="slide">
    <div class="garden-swipe-track" data-slide-target="track">
      <% @plant_pages.each do |page_plants| %>
        <div class="garden-swipe-slide">
          <% slots = (page_plants + Array.new(6, nil)).first(6) %>
          <div class="garden-grid">
            <% slots.each_with_index do |plant, i| %>
              <div class="<%= "garden-slot garden-slot--#{i + 1}" %>">
                <% if plant %>
                  <%= link_to plant_path(plant), class: "garden-tile", data: { turbo_frame: "_top" } do %>
                    <div class="tile-wrapper">
                      <% avatar = File.exist?(Rails.root.join("app/assets/images/avatars/#{plant.avatar_img}")) ? "avatars/#{plant.avatar_img}" : "avatars/undefined_pink_happy.png" %>
                      <%= image_tag "tile.svg", class: "tile-base", alt: "" %>
                      <div class="tile-plant-wrap">
                        <%= image_tag avatar, class: "tile-plant", alt: plant.nickname %>
                      </div>
                      <span class="tile-label"><%= plant.nickname %></span>
                    </div>
                  <% end %>
                <% else %>
                  <div class="garden-tile garden-tile--empty">
                    <div class="tile-wrapper">
                      <%= image_tag "tile.svg", class: "tile-base", alt: "" %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <% if @plant_pages.size > 1 %>
      <div class="garden-swipe-dots">
        <% @plant_pages.size.times do |i| %>
          <span class="slides-dot <%= 'active' if i == 0 %>" data-slide-target="dot"></span>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Bottom nav -->
  <div class="garden-bottom-nav">
    <button class="garden-nav-btn" disabled>
      <%= image_tag "shop.svg", alt: "shop", class: "garden-nav-icon" %>
    </button>
    <%= link_to new_plant_path, class: "garden-nav-btn garden-nav-btn--main" do %>
      <%= image_tag "new_photo_button.svg", alt: "add plant", class: "garden-nav-icon--main" %>
    <% end %>
    <button class="garden-nav-btn" data-action="click->reminders#openAudioSettings">
      <%= image_tag "reglage.svg", alt: "settings", class: "garden-nav-icon" %>
    </button>
  </div>

</div>
