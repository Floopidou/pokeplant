<% content_for :body_class, "garden-body" %>
<% content_for :hide_navbar, "true" %>

<div class="garden-page">

  <!-- Top badges -->
  <div class="garden-header">
    <div class="garden-badge">
      <%= image_tag "leaf_coin.png", class: "garden-badge-icon", alt: "plants" %>
      <%= @total_plant_count %>/6
    </div>
    <div class="garden-badge">
      <%= image_tag "leaf_coin.png", class: "garden-badge-icon garden-coin-icon", alt: "coins" %>
      <%= current_user.leaf_coins %>
    </div>
  </div>

  <!-- Title -->
  <h1 class="garden-title">The Garden</h1>

  <!-- 6 slots in isometric diamond: [1], [2,3], [4,5], [6] -->
  <% slots = (@paged_plants.to_a + Array.new(6, nil)).first(6) %>
  <div class="garden-grid">
    <% slots.each_with_index do |plant, i| %>
      <div class="garden-slot garden-slot--<%= i + 1 %>">
        <% if plant %>
          <%= link_to plant_path(plant), class: "garden-tile" do %>
            <div class="tile-wrapper">
              <% avatar = File.exist?(Rails.root.join("app/assets/images/avatars/#{plant.avatar_img}")) ? "avatars/#{plant.avatar_img}" : "avatars/undefined_pink_happy.svg" %>
              <%= image_tag "tile.svg", class: "tile-base", alt: "" %>
              <%= image_tag avatar, class: "tile-plant", alt: plant.nickname %>
              <span class="tile-label"><%= plant.nickname %></span>
            </div>
          <% end %>
        <% else %>
          <div class="garden-tile garden-tile--empty">
            <div class="tile-wrapper">
              <%= image_tag "tile.svg", class: "tile-base", alt: "" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Pagination — always 4 pages -->
  <div class="garden-pagination">
    <% (1..4).each do |p| %>
      <%= link_to plants_path(page: p),
          class: "garden-page-btn #{'active' if p == @current_page}" do %>
        <%= p %>
      <% end %>
    <% end %>
  </div>

  <!-- Bottom nav -->
  <div class="garden-bottom-nav">
    <%= link_to pots_path, class: "garden-nav-btn" do %>
      <%= image_tag "shop.svg", alt: "shop", class: "garden-nav-icon" %>
    <% end %>
    <%= link_to new_plant_path, class: "garden-nav-btn garden-nav-btn--main" do %>
      <%= image_tag "photo_button.svg", alt: "add plant", class: "garden-nav-icon--main" %>
    <% end %>
    <button class="garden-nav-btn">
      <%= image_tag "reglage.png", alt: "settings", class: "garden-nav-icon" %>
    </button>
  </div>

</div>
