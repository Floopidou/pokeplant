<h1>Add a new plant</h1>

<form action="<%= plants_path %>" method="post" enctype="multipart/form-data">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

  <div>
    <label for="photo">Photo of your plant</label>
    <input type="file" id="photo" name="photo" accept="image/*" capture="environment">
  </div>

  <div>
    <label for="nickname">Give it a nickname</label>
    <input type="text" id="nickname" name="nickname" placeholder="Choubidou" autocomplete="off">
  </div>

  <button type="submit">Identify my plant</button>
</form>
